generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GrupoAlimentar {
  id        String         @id @default(cuid())
  nome      String         @unique
  descricao String?
  ordem     Int            @default(0)
  createdAt DateTime       @default(now())
  alimentos AlimentoBase[]
}

model AlimentoBase {
  id                   String                   @id @default(cuid())
  nome                 String
  grupoId              String
  grupo                GrupoAlimentar           @relation(fields: [grupoId], references: [id])
  ativo                Boolean                  @default(true)
  carboidratosPor100g  Float?                   // g de carboidratos por 100g — usado para equivalência nutricional
  createdAt            DateTime                 @default(now())
  preparos             PreparoAlimento[]
  proteinasPedido      PedidoProteina[]
  equivalenciasOrigem  EquivalenciaAlimento[]   @relation("EquivOrigem")
  equivalenciasDestino EquivalenciaAlimento[]   @relation("EquivDestino")
}

model PreparoAlimento {
  id              String                @id @default(cuid())
  alimentoId      String
  alimento        AlimentoBase          @relation(fields: [alimentoId], references: [id], onDelete: Cascade)
  nome            String
  descricao       String?
  gramagem        Float?
  ativo           Boolean               @default(true)
  createdAt       DateTime              @default(now())
  itensLote       ItemLote[]
  itensPermitidos PedidoItemPermitido[]
}

model EquivalenciaAlimento {
  id                String       @id @default(cuid())
  alimentoOrigemId  String
  alimentoDestinoId String
  fator             Float
  descricao         String?
  createdAt         DateTime     @default(now())
  alimentoOrigem    AlimentoBase @relation("EquivOrigem", fields: [alimentoOrigemId], references: [id])
  alimentoDestino   AlimentoBase @relation("EquivDestino", fields: [alimentoDestinoId], references: [id])

  @@unique([alimentoOrigemId, alimentoDestinoId])
}

model Cliente {
  id          String        @id @default(cuid())
  nome        String
  email       String        @unique
  telefone    String?
  observacoes String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  pedidos     PedidoDieta[]
}

enum StatusPedido {
  PENDENTE
  GERADO
  AGUARDANDO_APROVACAO
  APROVADO
  REPROVADO
  EM_PRODUCAO
  CONCLUIDO
  CANCELADO
}

model PedidoDieta {
  id                String                @id @default(cuid())
  clienteId         String
  cliente           Cliente               @relation(fields: [clienteId], references: [id])
  totalPratos       Int
  maxRepeticoes     Int
  minRepeticoesLote Int                   @default(2)
  observacoes       String?
  obsLegumes        String?               // OBS sobre legumes proibidos (exibida em destaque na produção)
  nutricionista     String?               // Nome do nutricionista responsável (opcional)
  status            StatusPedido          @default(PENDENTE)
  valorTotal        Float?                // Valor cobrado pelo pedido (R$)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  proteinas         PedidoProteina[]
  itensPermitidos   PedidoItemPermitido[]
  versoes           CardapioVersao[]
  aprovacao         AprovacaoCliente?
  ordemProducao     OrdemProducao?
}

/// Distribuição de proteína — soma de quantidadePratos = totalPratos
model PedidoProteina {
  id               String       @id @default(cuid())
  pedidoId         String
  pedido           PedidoDieta  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  alimentoBaseId   String
  alimentoBase     AlimentoBase @relation(fields: [alimentoBaseId], references: [id])
  gramagem         Float
  quantidadePratos Int
  preparosIds      String[]     @default([]) // IDs dos preparos permitidos; vazio = todos os ativos

  @@unique([pedidoId, alimentoBaseId])
}

/// Preparos selecionados para o cardápio — Carboidrato | Leguminosa | Legume
/// Seleção em dois níveis: o usuário escolhe quais preparos específicos participam.
/// A gramagem é definida uma vez por grupo (mesma para todos os preparos do grupo).
/// Para carboidratos, o algoritmo ajusta a gramagem via tabela nutricional (TACO).
model PedidoItemPermitido {
  id           String          @id @default(cuid())
  pedidoId     String
  pedido       PedidoDieta     @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  grupoNome    String          // 'Carboidrato', 'Leguminosa', 'Legume'
  preparoId    String
  preparo      PreparoAlimento @relation(fields: [preparoId], references: [id])
  gramagemBase Float

  @@unique([pedidoId, preparoId])
}

/// Versão/geração de cardápio — histórico preservado; apenas uma ativa por pedido
model CardapioVersao {
  id        String         @id @default(cuid())
  pedidoId  String
  pedido    PedidoDieta    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  numero    Int
  ativo     Boolean        @default(true)
  criadoEm DateTime        @default(now())
  lotes     LoteCardapio[]

  @@unique([pedidoId, numero])
}

model LoteCardapio {
  id         String         @id @default(cuid())
  versaoId   String
  versao     CardapioVersao @relation(fields: [versaoId], references: [id], onDelete: Cascade)
  quantidade Int
  itens      ItemLote[]
}

model ItemLote {
  id          String          @id @default(cuid())
  loteId      String
  lote        LoteCardapio    @relation(fields: [loteId], references: [id], onDelete: Cascade)
  preparoId   String
  preparo     PreparoAlimento @relation(fields: [preparoId], references: [id])
  gramagem    Float
  grupoNome   String
  nomeManual  String?
  obs         String?
}

enum StatusAprovacao {
  PENDENTE
  APROVADO
  REPROVADO
}

model AprovacaoCliente {
  id            String          @id @default(cuid())
  pedidoId      String          @unique
  status        StatusAprovacao @default(PENDENTE)
  dataAprovacao DateTime?
  observacoes   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  pedido        PedidoDieta     @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

enum StatusOrdem {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model OrdemProducao {
  id                String      @id @default(cuid())
  pedidoId          String      @unique
  status            StatusOrdem @default(PENDENTE)
  dataGeracao       DateTime    @default(now())
  dataPrevisao      DateTime?
  observacoes       String?
  itensConsolidados Json
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  pedido            PedidoDieta @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

// ── Portal do Cliente ─────────────────────────────────────────────────────

enum StatusSolicitacao {
  AGUARDANDO
  EM_ORCAMENTO
  ORCAMENTO_ENVIADO
  APROVADO
  REPROVADO
}

model SolicitacaoOrcamento {
  id           String             @id @default(cuid())
  nome         String
  email        String
  telefone     String?
  totalPratos  Int
  proteinas    Json               // [{alimentoNome, gramagem, quantidade}]
  carboidrato  Json?              // {gramagem, alimentoNomes[]}
  leguminosa   Json?              // {gramagem, alimentoNomes[]}
  legume       Json?              // {gramagem, alimentoNomes[], obs}
  molhos       Json?              // [string]
  observacoes  String?
  status       StatusSolicitacao  @default(AGUARDANDO)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}
